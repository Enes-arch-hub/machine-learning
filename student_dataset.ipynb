    "import numpy as np\n",
    "students = np.array([\n",
    "    [80, 70, 1],\n",
    "    [60, 75, 0],\n",
    "    [90, 88, 1],\n",
    "    [50, 40, 0]\n",
    "])\n",
    "x = students[:, :-1]\n",
    "y = students[:, -1]\n",
    "\n",
    "print(\"X:\")\n",
    "print(x)\n",
    "print(\"y:\")\n",
    "print(y)"
   ]
  }
